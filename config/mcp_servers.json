{
  "comment": "External MCP servers — tools from each server are auto-registered into the agent tool pool. Roles declare tool_access by category (e.g. 'browser') to receive matching tools.",
  "servers": [
    {
      "id": "playwright",
      "name": "Playwright MCP",
      "transport": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--headless"],
      "category": "browser",
      "enabled": true
    },
    {
      "id": "tmux",
      "name": "tmux-mcp-rs",
      "transport": "stdio",
      "command": "tmux-mcp-rs",
      "args": [
        "--shell-type", "bash",
        "--socket", "/tmp/mojo-agent.sock",
        "--config", "/home/alex/.memory/config/tmux-mcp.toml"
      ],
      "category": "terminal",
      "enabled": true
    }
  ]
}
