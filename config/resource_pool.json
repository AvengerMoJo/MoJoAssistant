{
  "comment": "Unified resource pool — single source of truth for all LLM resources. User overrides live in ~/.memory/config/resource_pool.json. Add new accounts there, not here.",
  "tier_policy": {
    "free":     { "auto_approve": true },
    "free_api": { "auto_approve": true },
    "paid":     { "auto_approve": false }
  },
  "selection_strategy": "priority_then_availability",
  "resources": {
    "lmstudio": {
      "type": "local",
      "provider": "openai",
      "base_url": "http://localhost:8080/v1",
      "api_key_env": "LMSTUDIO_API_KEY",
      "model": null,
      "dynamic_discovery": true,
      "tier": "free",
      "priority": 1,
      "enabled": true,
      "context_limit": 32768,
      "output_limit": 8192,
      "description": "Local LMStudio server — model auto-detected from /v1/models at runtime"
    },
    "openrouter_avengermojo": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_AVENGERMOJO",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 10,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (avengermojo)"
    },
    "openrouter_elmntri": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_ELNTRI",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 10,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (elmntri)"
    },
    "openrouter_tinyi": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_TINYI",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 10,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (tinyi)"
    },
    "openrouter_yiai": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_YIAI",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 11,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (yiai fallback)"
    }
  }
}
