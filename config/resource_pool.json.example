{
  "comment": "Unified resource pool — single source of truth for all LLM resources. User overrides live in ~/.memory/config/resource_pool.json. Add new accounts there, not here.",
  "_example_note": "OpenRouter entries below show the pattern for multi-account free-tier rotation. Replace account_a/b/c with your own OpenRouter account names and matching env vars.",
  "tier_policy": {
    "free":     { "auto_approve": true },
    "free_api": { "auto_approve": true },
    "paid":     { "auto_approve": false }
  },
  "selection_strategy": "priority_then_availability",
  "resources": {
    "lmstudio": {
      "type": "local",
      "provider": "openai",
      "base_url": "http://localhost:8080/v1",
      "api_key_env": "LMSTUDIO_API_KEY",
      "model": null,
      "dynamic_discovery": true,
      "tier": "free",
      "priority": 1,
      "enabled": true,
      "context_limit": 32768,
      "output_limit": 8192,
      "description": "Local LMStudio server — model auto-detected from /v1/models at runtime"
    },
    "openrouter_account_a": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_ACCOUNT_A",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 10,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (account A)"
    },
    "openrouter_account_b": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_ACCOUNT_B",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 10,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (account B)"
    },
    "openrouter_account_c": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_ACCOUNT_C",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 10,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (account C)"
    },
    "openrouter_account_d": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY_ACCOUNT_D",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 11,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "account_group": "openrouter_free",
      "description": "OpenRouter free-tier routing (account D — lower priority fallback)"
    }
  }
}
