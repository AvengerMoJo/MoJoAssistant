{
  "comment": "Unified resource pool — single source of truth for all LLM resources. User overrides live in ~/.memory/config/resource_pool.json. Add new accounts there, not here.",
  "_note": "Inline api_key is the primary pattern for orchestrated setups (users add resources via MCP config() tool). Use api_key_env only when the key lives in an existing environment variable that you manage externally.",
  "_example_note": "OpenRouter entries below show both patterns. Inline api_key is preferred for MCP-orchestrated config. Use api_key_env for keys already in your environment or managed outside MoJoAssistant.",
  "tier_policy": {
    "free":     { "auto_approve": true },
    "free_api": { "auto_approve": true },
    "paid":     { "auto_approve": false }
  },
  "selection_strategy": "priority_then_availability",
  "resources": {
    "lmstudio": {
      "type": "local",
      "provider": "openai",
      "base_url": "http://localhost:8080/v1",
      "model": null,
      "dynamic_discovery": true,
      "tier": "free",
      "priority": 1,
      "enabled": true,
      "context_limit": 32768,
      "output_limit": 8192,
      "description": "Local LMStudio server — model auto-detected from /v1/models at runtime"
    },
    "openrouter_my_account": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key": "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 10,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "description": "OpenRouter free-tier routing — edit or replace via config(action='resource_add')"
    },
    "openrouter_via_env": {
      "type": "api",
      "provider": "openai-compatible",
      "base_url": "https://openrouter.ai/api/v1",
      "api_key_env": "OPENROUTER_API_KEY",
      "model": "openrouter/auto",
      "tier": "free_api",
      "priority": 11,
      "enabled": true,
      "context_limit": 131072,
      "output_limit": 8192,
      "description": "OpenRouter via env var — key resolved from MOJO_MEMORY/resource_pool.env at runtime"
    }
  }
}
