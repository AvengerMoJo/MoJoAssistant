{
  "_comment": "Notification adapters config. Copy this file to notifications_config.json and customise.",
  "_comment2": "Each adapter is independent — its own channel, cursor, and filter. Enabling one does not affect others.",
  "_comment3": "sse_stream and mcp_poll are always active (built-in). Only push adapters (ntfy, fcm) need configuration here.",

  "adapters": [

    {
      "_comment": "=== ntfy — push notifications to Android / iOS / desktop / web ===",
      "_comment_setup": "--- PRIVATE TOPIC SETUP (recommended) ---",
      "_comment2": "Step 1: Create a free account at https://ntfy.sh",
      "_comment3": "Step 2: Account → Access Tokens → Generate token → save to .env as NTFY_TOKEN=tk_xxx",
      "_comment4": "Step 3: Reserve the topic: Account → Reserved Topics → Add → YOUR_TOPIC_NAME",
      "_comment5": "Step 4: Set ACL on the reserved topic: your user = read+write, Everyone = deny",
      "_comment6": "        (This blocks strangers from subscribing or publishing to your topic)",
      "_comment7": "Step 5: Phone app: Settings → Account → Log in with your ntfy.sh credentials",
      "_comment8": "        Then subscribe to YOUR_TOPIC_NAME — the app will use your account for auth",
      "_comment9": "Step 6: Set enabled=true below, replace YOUR_TOPIC_NAME, set MOJO_BASE_URL in .env",

      "id": "ntfy_push",
      "type": "ntfy",
      "enabled": false,

      "endpoint": "https://ntfy.sh/YOUR_TOPIC_NAME",
      "_endpoint_note": "Topic name must match what you reserved and subscribed to in the ntfy app",

      "auth_var": "NTFY_TOKEN",
      "_auth_note": "Env var holding your ntfy Bearer token. Required for protected topics. Remove for public topics.",

      "poll_interval": 30,
      "_poll_note": "How often (seconds) to check for new events. Lower = faster notifications. Use 5 for testing.",

      "filter": {
        "min_severity": "warning",
        "_severity_note": "Only send events at this severity or above. Values: info / warning / error / critical",

        "notify_user_only": true,
        "_notify_note": "Only send events flagged as user-facing (task_failed, system errors, etc.)",

        "event_types": ["task_failed", "task_completed", "system_notification", "task_waiting_for_input", "task_started", "task_cancelled"],
        "_types_note": "Allowlist of event types to forward. Remove this line to forward all types that pass severity filter."
      }
    },

    {
      "_comment": "=== FCM — Firebase Cloud Messaging (Android) — not yet implemented ===",
      "id": "fcm_android",
      "type": "fcm",
      "enabled": false,
      "key_var": "FCM_SERVER_KEY",
      "device_token_var": "FCM_DEVICE_TOKEN",
      "filter": {
        "min_severity": "warning",
        "notify_user_only": true
      }
    }

  ]
}
