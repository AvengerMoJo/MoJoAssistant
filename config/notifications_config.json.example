{
  "adapters": [
    {
      "id": "sse_stream",
      "type": "sse",
      "enabled": true,
      "description": "Live SSE stream at GET /events/tasks — for browser/WebSocket clients",
      "filter": { "min_severity": "info", "notify_user_only": false }
    },
    {
      "id": "mcp_poll",
      "type": "mcp_poll",
      "enabled": true,
      "description": "get_recent_events MCP tool — for Claude Desktop and other MCP clients",
      "filter": { "min_severity": "info", "notify_user_only": false }
    },
    {
      "id": "ntfy_push",
      "type": "ntfy",
      "enabled": false,
      "description": "Push notifications via ntfy. Works with ntfy.sh or self-hosted.",
      "endpoint": "https://ntfy.sh/YOUR_TOPIC_NAME",
      "auth_var": "NTFY_TOKEN",
      "filter": {
        "min_severity": "warning",
        "notify_user_only": true,
        "event_types": ["task_failed", "task_completed", "system_notification"]
      }
    },
    {
      "id": "fcm_android",
      "type": "fcm",
      "enabled": false,
      "description": "Firebase Cloud Messaging — Android push notifications",
      "key_var": "FCM_SERVER_KEY",
      "device_token_var": "FCM_DEVICE_TOKEN",
      "filter": {
        "min_severity": "warning",
        "notify_user_only": true
      }
    }
  ]
}
