{
  "default_tasks": [
    {
      "id": "scott_daily_news_0600",
      "type": "assistant",
      "cron": "0 6 * * *",
      "priority": "high",
      "description": "Scott daily news briefing — 6 AM every day",
      "config": {
        "role_id": "scott",
        "goal": "Collect and synthesize today's tech and AI news briefing. Cover at least 3 independent source categories. Save the briefing to memory with today's date.",
        "max_iterations": 20,
        "tier_preference": "free"
      },
      "resources": { "requires_gpu": false }
    },
    {
      "id": "ahman_weekly_security_review",
      "type": "assistant",
      "cron": "0 4 * * 0",
      "priority": "low",
      "description": "Weekly Ahman security review — runs Sunday 4am",
      "config": {
        "role_id": "ahman",
        "goal": "Perform a weekly security review of MoJoAssistant. Check for any new files or config changes that may affect the security posture. Summarize findings.",
        "max_iterations": 10,
        "tier_preference": "free",
        "available_tools": ["read_file", "list_files", "search_in_files", "memory_search"],
        "final_answer_requirements": { "min_length": 100 }
      },
      "resources": { "requires_gpu": false }
    },
    {
      "id": "config_doctor_daily",
      "type": "assistant",
      "cron": "0 9 * * *",
      "priority": "low",
      "description": "Daily runtime config validation — runs ConfigDoctor and writes digest to memory. Copy to ~/.memory/config/scheduler_config.json to enable.",
      "config": {
        "role_id": "ahman",
        "goal": "Run the MoJoAssistant configuration doctor to validate system health. Use bash_exec to run: cd /home/alex/Development/Personal/MoJoAssistant && python3 -c \"from app.config.doctor import ConfigDoctor; import json; r = ConfigDoctor().run_all_checks(); errors = [c for c in r.checks if c.status == 'error']; warns = [c for c in r.checks if c.status == 'warn']; print(f'ERRORS: {len(errors)}, WARNS: {len(warns)}'); [print(f'  ERROR [{c.category}/{c.id}] {c.message}') for c in errors]; [print(f'  WARN  [{c.category}/{c.id}] {c.message}') for c in warns]\" Then save the output as your FINAL_ANSWER.",
        "max_iterations": 5,
        "tier_preference": "free",
        "available_tools": ["bash_exec", "add_conversation"],
        "notify_on_completion": false,
        "final_answer_requirements": { "min_length": 20 }
      },
      "resources": { "requires_gpu": false }
    },
    {
      "id": "dreaming_nightly_offpeak_default",
      "type": "dreaming",
      "cron": "0 3 * * *",
      "priority": "low",
      "description": "Automatic nightly Dreaming consolidation (off-peak)",
      "config": {
        "automatic": true,
        "quality_level": "basic",
        "off_peak_start": "01:00",
        "off_peak_end": "05:00",
        "enforce_off_peak": true,
        "lookback_messages": 200
      },
      "resources": { "requires_gpu": true }
    }
  ]
}
