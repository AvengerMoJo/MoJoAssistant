{
  "comment": "Unified LLM config — single source of truth for LLM interfaces AND resource pool. Copy to llm_config.json and customise. Runtime overrides go in ~/.memory/config/llm_config.json.",

  "tier_policy": {
    "free":     { "auto_approve": true },
    "free_api": { "auto_approve": true },
    "paid":     { "auto_approve": false }
  },
  "selection_strategy": "priority_then_availability",

  "local_models": {
    "my-local-model": {
      "type": "local",
      "provider": "openai",
      "path": "/path/to/model.gguf",
      "context_length": 32768,
      "context_limit": 32768,
      "output_limit": 8192,
      "server_url": null,
      "tier": "free",
      "priority": 5,
      "enabled": true,
      "description": "Local model via llama.cpp"
    }
  },

  "api_models": {
    "lmstudio": {
      "provider": "openai",
      "base_url": "http://localhost:8080/v1",
      "key_var": "LMSTUDIO_API_KEY",
      "model": "any-model-loaded-in-lmstudio",
      "context_limit": 32768,
      "output_limit": 8192,
      "type": "local",
      "tier": "free",
      "priority": 1,
      "enabled": true,
      "description": "Local LMStudio server"
    },

    "openrouter": {
      "account_a": {
        "provider": "openai-compatible",
        "base_url": "https://openrouter.ai/api/v1",
        "key_var": "OPENROUTER_API_KEY_A",
        "model": "openrouter/auto",
        "context_limit": 131072,
        "output_limit": 8192,
        "type": "api",
        "tier": "free_api",
        "priority": 10,
        "enabled": true,
        "account_group": "openrouter_free",
        "description": "OpenRouter free-tier (account A)"
      }
    },

    "anthropic": {
      "provider": "claude",
      "key_var": "ANTHROPIC_API_KEY",
      "model": "claude-haiku-4-5-20251001",
      "context_limit": 200000,
      "output_limit": 8192,
      "type": "api",
      "tier": "paid",
      "priority": 50,
      "enabled": true,
      "description": "Anthropic Claude API"
    }
  },

  "task_assignments": {
    "interactive_cli": "lmstudio",
    "dreaming_chunking": "lmstudio",
    "dreaming_synthesis": "lmstudio",
    "default": "lmstudio"
  },

  "default_interface": "lmstudio"
}
