# OpenCode Manager Global Configuration
# This file contains global credentials used by all OpenCode instances
# Location: ~/.memory/opencode-manager.env

# Global OpenCode password (used by all OpenCode instances)
# This protects OpenCode web interfaces if accidentally exposed
# Generate with: openssl rand -hex 16
OPENCODE_PASSWORD=CHANGE_ME_REQUIRED

# Global MCP bearer token (used by the global MCP tool on port 3005)
# Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=CHANGE_ME_REQUIRED

# OpenCode binary path (auto-detected from PATH if not set)
# OPENCODE_BIN=opencode
# Path to opencode-mcp-tool repository (required for global MCP tool)
# OPENCODE_MCP_TOOL_PATH=/path/to/opencode-mcp-tool
