# MoJoAssistant Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# HTTP Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=*

# MCP Authentication (Required for secure access)
MCP_API_KEY=demo_key_for_development
MCP_REQUIRE_AUTH=false

# Lean MCP mode — strips param descriptions + truncates tool descriptions to 1 line
# Reduces tools/list payload ~43% (30KB → 17KB). Fixes 413 errors on some MCP clients.
# Set to 1 to enable. Full action menus still available at runtime via tool help.
MOJO_LEAN_MCP=0

# Dashboard — read-only monitoring UI at /dashboard
# Falls back to MCP_API_KEY if not set
DASHBOARD_PASSWORD=change_me

# Public base URL — required for ntfy HITL reply action buttons
# Set to your Cloudflare/reverse-proxy domain; leave blank to omit reply buttons
MOJO_BASE_URL=https://mojo.example.com

# Environment and debugging
ENVIRONMENT=development
DEBUG=false

# =============================================================================
# OPTIONAL FEATURES (Enhance functionality)
# =============================================================================

# OpenCode Manager (disabled by default)
# Manages AI coding agent projects via opencode-mcp-tool
# Requires ~/.memory/opencode-manager.env config file when enabled
ENABLE_OPENCODE=false
# OPENCODE_BIN=opencode                    # Path to opencode binary (auto-detected from PATH)
# CODING_AGENT_MCP_BIN=coding-agent-mcp    # Path to coding-agent-mcp binary (auto-detected from PATH)

# Claude Code Manager (disabled by default)
# Manages Claude Code CLI subprocess lifecycle
# Requires: claude CLI installed and authenticated
ENABLE_CLAUDE_CODE=false
# CLAUDE_BIN=claude                      # Path to claude binary (auto-detected from PATH)

# Google Custom Search API Configuration (Optional - enhances web search)
# Get your API key from: https://developers.google.com/custom-search/v1/overview
# Get your Search Engine ID from: https://programmablesearchengine.google.com/
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# =============================================================================
# OAUTH 2.1 AUTHENTICATION (For Claude Connectors)
# =============================================================================

# OAuth 2.1 Resource Server Configuration
# Enable OAuth 2.1 for Claude Connectors compatibility
OAUTH_ENABLED=false
# OAUTH_ISSUER=https://your-auth-provider.com
# OAUTH_AUDIENCE=https://your-mcp-server.com
# OAUTH_JWKS_URI=https://your-auth-provider.com/.well-known/jwks.json

# OAuth Authorization Server Endpoints (Optional)
# OAUTH_AUTHORIZATION_ENDPOINT=https://your-auth-provider.com/oauth/authorize
# OAUTH_TOKEN_ENDPOINT=https://your-auth-provider.com/oauth/token

# OAuth Resource Server Settings (Optional)
# OAUTH_RESOURCE_SERVER_ID=your-resource-server-id

# OAuth Token Validation (Advanced)
# OAUTH_VERIFY_SIGNATURE=true
# OAUTH_VERIFY_AUDIENCE=true
# OAUTH_VERIFY_ISSUER=true
# OAUTH_VERIFY_EXP=true

# OAuth Scopes Configuration
# OAUTH_SUPPORTED_SCOPES=mcp:read,mcp:write,mcp:admin
# OAUTH_REQUIRED_SCOPE=mcp:read

# OAuth Advanced Settings
# OAUTH_ALGORITHM=RS256
# OAUTH_TOKEN_CACHE_TTL=300

# OAuth Authorization Server Settings (Full OAuth Server Mode)
# Enable full OAuth authorization server for chatmcp compatibility
# OAUTH_AUTHORIZATION_SERVER_ENABLED=true
# OAUTH_API_KEY_MODE=true                 # Allow API key as Bearer token
# OAUTH_AUTO_APPROVE=true                 # Auto-approve for personal use
# OAUTH_AUTHORIZATION_CODE_TTL=600        # Authorization code TTL (seconds)
# OAUTH_ACCESS_TOKEN_TTL=3600             # Access token TTL (seconds)
# OAUTH_REFRESH_TOKEN_TTL=2592000         # Refresh token TTL (seconds)
# OAUTH_PUBLIC_CLIENT_ENABLED=true        # Allow public clients (no client_id)

# =============================================================================
# LLM PROVIDER CONFIGURATION (For AI capabilities)
# =============================================================================
# OpenAI API (ChatGPT, GPT-4)
# OPENAI_API_KEY=your-openai-api-key

# Anthropic API (Claude)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Google API (Gemini)
# GOOGLE_API_KEY=your-google-api-key

# OpenRouter API (Multiple models)
# OPEN_ROUTER_KEY=your-openrouter-api-key

# Local model paths (For local LLM deployment)
# LOCAL_MODEL_PATH=/path/to/local/models

# LM Studio (OpenAI-compatible local API with Bearer auth)
# Typical endpoint: http://localhost:8080/v1
# Set API token directly OR load it from a local key file.
# LMSTUDIO_BASE_URL=http://localhost:8080/v1
# LMSTUDIO_API_KEY=your_lmstudio_api_token_here
# LMSTUDIO_API_KEY_FILE=~/.keys/local_lmstudio.key

# =============================================================================
# NOTIFICATIONS (Push Adapters)
# =============================================================================
# ntfy push notifications (Android, iOS, desktop, web)
# See docs/guides/NOTIFICATIONS_SETUP.md for full setup instructions.
# Configure adapters in config/notifications_config.json (copy from .example).
#
# ntfy.sh account token (required for protected/private topics)
# Get from: ntfy.sh → Account → Access Tokens → Generate
# NTFY_TOKEN=tk_yourtokenhere
#
# FCM (Android Firebase Cloud Messaging) - future adapter
# FCM_SERVER_KEY=your-fcm-server-key
# FCM_DEVICE_TOKEN=your-device-registration-token

# =============================================================================
# SEARCH CONFIGURATION
# =============================================================================
# Web search functionality
SEARCH_ENABLED=true

# Google Search keys: see EXTERNAL API KEYS section below

# =============================================================================
# MEMORY AND KNOWLEDGE SYSTEM
# =============================================================================
# Embedding model for semantic search
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Multi-model embedding support
MULTI_MODEL_ENABLED=false

# Vector storage backend
VECTOR_STORE=qdrant

# Storage paths (optional — defaults shown are used automatically if unset)
# MEMORY_PATH=~/.memory  ← tilde is safe, the server expands it correctly
# KNOWLEDGE_PATH=~/.memory/knowledge

# Memory system tuning
MAX_CONTEXT_ITEMS=10
EMBEDDING_CACHE_TTL=3600

# =============================================================================
# LOGGING AND DEBUGGING
# =============================================================================
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log output format
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Log file path (optional)
# LOG_FILE=/path/to/log/file.log

# Console logging
LOG_CONSOLE=true

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================
# OpenRouter — access to free/paid cloud models (claude, gemini, mistral, etc.)
# OPEN_ROUTER_KEY=sk-or-...

# Google Search (Custom Search API)
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# HuggingFace — model downloads and inference
# HUGGINGFACE_TOKEN=hf_...

# ntfy — push notification server token (self-hosted or ntfy.sh)
# NTFY_TOKEN=tk_...

# =============================================================================
# LOCAL MODEL / LMSTUDIO
# =============================================================================
# Path to local model weights (used by some loaders)
# LOCAL_MODEL_PATH=/path/to/models

# =============================================================================
# CODING AGENT INTEGRATION
# =============================================================================
# Path to the Claude Code / OpenCode binary
# OPENCODE_BIN=opencode
# CODING_AGENT_MCP_BIN=/path/to/coding-agent-mcp

# Path to the MCP tool config for coding agents
# OPENCODE_MCP_TOOL_PATH=~/.config/opencode/mcp.json

# =============================================================================
# MCP GLOBAL TOOL SERVER
# =============================================================================
# Bearer token for the global MCP tool proxy (used by coding agents)
# GLOBAL_MCP_BEARER_TOKEN=your-bearer-token
# Port the global MCP tool server listens on
# GLOBAL_MCP_TOOL_PORT=8001

# =============================================================================
# OAUTH / AUTHORIZATION SERVER
# =============================================================================
# Enable the built-in OAuth 2.0 authorization server
OAUTH_AUTHORIZATION_SERVER_ENABLED=false

# Token lifetimes (seconds)
OAUTH_ACCESS_TOKEN_TTL=3600
OAUTH_AUTHORIZATION_CODE_TTL=600
OAUTH_REFRESH_TOKEN_TTL=86400
OAUTH_TOKEN_CACHE_TTL=300

# Algorithm and audience
OAUTH_ALGORITHM=HS256
OAUTH_AUDIENCE=mojo-assistant
OAUTH_REQUIRED_SCOPE=mojo:access
OAUTH_SUPPORTED_SCOPES=mojo:access,mojo:admin

# Verification flags
OAUTH_VERIFY_SIGNATURE=true
OAUTH_VERIFY_EXP=true
OAUTH_VERIFY_ISSUER=true
OAUTH_VERIFY_AUDIENCE=true

# Client settings
OAUTH_API_KEY_MODE=header
OAUTH_PUBLIC_CLIENT_ENABLED=false
OAUTH_AUTO_APPROVE=false

# =============================================================================
# NOTES
# =============================================================================
# - For quick start, leave MCP_REQUIRE_AUTH=false
# - For production, set MCP_REQUIRE_AUTH=true and use a secure API key
# - Google API setup is optional but recommended for better web search
# - All API keys are optional - MoJoAssistant works without them
# - Never commit your actual API keys to version control
