# OpenCode Sandbox Image (Docker-only, no CubeSandbox dependency)
#
# Standalone image for use with DockerSandboxBackend or docker_sandbox_* agentic tools.
#
# Build:
#   docker build -t opencode-sandbox:latest -f docker/opencode-sandbox/Dockerfile.standalone .

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV BUN_INSTALL=/root/.bun
ENV PATH="/root/.bun/bin:$PATH"

# Base packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    unzip \
    build-essential \
    python3 python3-pip python3-venv \
    git \
    openssh-client \
    ca-certificates \
    sudo \
    && rm -rf /var/lib/apt/lists/*

# Install bun
RUN curl -fsSL https://bun.sh/install | bash

# Install OpenCode globally
RUN bun install -g opencode-ai

# Create workspace
RUN mkdir -p /workspace
WORKDIR /workspace

EXPOSE 4173

HEALTHCHECK --interval=2s --timeout=2s --start-period=10s --retries=15 \
  CMD curl -fsS http://127.0.0.1:4173/api/health || exit 1

CMD ["opencode", "serve", "--port", "4173", "--hostname", "0.0.0.0", "--print-logs"]
