# MoJoAssistant — Development / Test Image
#
# Includes test tools, hot reload, and source mounted as volume.
# Usage:
#   docker compose -f docker/docker-compose.dev.yml up
#
# Or manually:
#   docker build -f docker/Dockerfile.dev -t mojoassistant-dev .
#   docker run -p 8000:8000 --env-file .env \
#     -v $(pwd):/app -v ~/.memory:/home/mojo/.memory \
#     mojoassistant-dev

FROM python:3.12-slim

# ── System deps ──────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates \
        # Network tools useful for Ahman-style agentic tasks in dev
        iputils-ping net-tools iproute2 nmap \
    && rm -rf /var/lib/apt/lists/*

# ── Non-root user ─────────────────────────────────────────────────────────────
RUN useradd -m -u 1000 -s /bin/bash mojo

# ── Python deps ──────────────────────────────────────────────────────────────
WORKDIR /app
COPY requirements-runtime.txt .
RUN pip install --no-cache-dir -r requirements-runtime.txt

# Dev / test extras
RUN pip install --no-cache-dir \
    pytest pytest-asyncio pytest-cov \
    watchdog \
    httpx

# ── Source is mounted at runtime (not baked in) ───────────────────────────────
# This allows hot reload without rebuilding the image.

RUN mkdir -p /home/mojo/.memory && chown -R mojo:mojo /home/mojo/.memory

USER mojo
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app \
    MOJO_ENV=development

EXPOSE 8000

# Hot-reload via watchdog
CMD ["python", "-m", "watchdog.watchmedo", "auto-restart", \
     "--directory=/app", "--pattern=*.py", "--recursive", "--", \
     "python", "unified_mcp_server.py", "--mode", "http", "--port", "8000"]
