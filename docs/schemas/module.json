{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MoJo Module Descriptor",
  "description": "Descriptor for a MoJoAssistant pluggable module",
  "type": "object",
  "required": ["name", "version", "contract_version", "provider_type", "entry_point"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique module identifier (e.g., 'mojo_memory', 'mojo_dream')",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": {
      "type": "string",
      "description": "Module version (semver)",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "contract_version": {
      "type": "string",
      "description": "Contract version this module implements (major.minor)",
      "pattern": "^\\d+\\.\\d+$"
    },
    "provider_type": {
      "type": "string",
      "enum": ["memory", "dream", "persona", "growth", "skill"],
      "description": "Type of provider this module implements"
    },
    "entry_point": {
      "type": "string",
      "description": "Dotted path to the provider adapter class"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the module"
    },
    "capabilities": {
      "type": "object",
      "description": "Module-specific capabilities",
      "additionalProperties": true
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Other module names this module depends on"
    },
    "data_contracts": {
      "type": "object",
      "description": "Data contract versions this module implements",
      "additionalProperties": {"type": "string"}
    }
  }
}
